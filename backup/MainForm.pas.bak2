procedure TfrmMain.mnuOpenClick(Sender: TObject);
begin
  if dlgOpen.Execute then
  begin
    // 根据文件扩展名确定配置类型
    if SameText(ExtractFileExt(dlgOpen.FileName), '.ini') then
      OpenConfigEditor('INI', dlgOpen.FileName)
    else if SameText(ExtractFileExt(dlgOpen.FileName), '.json') then
      OpenConfigEditor('JSON', dlgOpen.FileName)
    else
      ShowMessage('不支持的配置文件类型');
  end;
end;

procedure TfrmMain.mnuSaveClick(Sender: TObject);
begin
  SaveCurrentConfig;
end;

procedure TfrmMain.mnuSaveAsClick(Sender: TObject);
var
  PageInfo: TConfigPageInfo;
  Editor: TMemo;
begin
  PageInfo := GetCurrentPageInfo;
  
  if PageInfo.TabSheet = nil then
    Exit;
    
  // 获取当前编辑器内容
  if PageInfo.TabSheet.ControlCount = 0 then
    Exit;
    
  Editor := PageInfo.TabSheet.Controls[0] as TMemo;
  
  // 设置对话框初始文件名
  dlgSave.FileName := ExtractFileName(PageInfo.ConfigPath);
  
  if dlgSave.Execute then
  begin
    try
      // 保存编辑器内容到新文件
      Editor.Lines.SaveToFile(dlgSave.FileName);
      
      // 重新加载树视图
      InitializeTree;
      
      // 打开新保存的文件
      if SameText(ExtractFileExt(dlgSave.FileName), '.ini') then
        OpenConfigEditor('INI', dlgSave.FileName)
      else if SameText(ExtractFileExt(dlgSave.FileName), '.json') then
        OpenConfigEditor('JSON', dlgSave.FileName);
    except
      on E: Exception do
      begin
        ShowMessage('保存配置时出错：' + E.Message);
      end;
    end;
  end;
end;

