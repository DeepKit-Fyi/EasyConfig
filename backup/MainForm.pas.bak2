  TreeHelper.ToggleEmptyCategories(tvConfig);
  
  // 记录调试信息
  FormHelper.AddDebugText(meoDebug, '切换显示/隐藏空分类节点');
end;

procedure TfrmMain.btnSvgExpandCollapseClick(Sender: TObject);
var
  i: Integer;
  AllExpanded: Boolean;
begin
  if tvConfig.Items.Count = 0 then
    Exit;
    
  // 检查是否所有节点都已展开
  AllExpanded := True;
  for i := 0 to tvConfig.Items.Count - 1 do
  begin
    if (tvConfig.Items[i].Level = 0) and tvConfig.Items[i].HasChildren and not tvConfig.Items[i].Expanded then
    begin
      AllExpanded := False;
      Break;
    end;
  end;
  
  // 展开或收缩所有节点
  tvConfig.Items.BeginUpdate;
  try
    if AllExpanded then
    begin
      // 如果所有节点都已展开，则全部收缩
      for i := 0 to tvConfig.Items.Count - 1 do
      begin
        if (tvConfig.Items[i].Level = 0) and tvConfig.Items[i].HasChildren then
          tvConfig.Items[i].Collapse(True);
      end;
      FormHelper.AddDebugText(meoDebug, '所有节点已收缩');
    end
    else
    begin
      // 否则全部展开
      for i := 0 to tvConfig.Items.Count - 1 do
      begin
        if (tvConfig.Items[i].Level = 0) and tvConfig.Items[i].HasChildren then
          tvConfig.Items[i].Expand(True);
      end;
      FormHelper.AddDebugText(meoDebug, '所有节点已展开');
    end;
  finally
    tvConfig.Items.EndUpdate;
  end;
end;

procedure TfrmMain.ValueListEditorDblClick(Sender: TObject);
begin
  // 在双击时，如果点击的是第二列（值列），则启动编辑
  if (FValueListEditor.Col = 1) and (FValueListEditor.Row > 0) then
  begin
    FValueListEditor.EditorMode := True;
    FormHelper.AddDebugText(meoDebug, '开始编辑值: ' + FValueListEditor.Keys[FValueListEditor.Row]);
  end
  else if (FValueListEditor.Col = 0) and (FValueListEditor.Row > 0) then
  begin
    // 如果点击的是第一列（键名），则调用重命名功能
    RenameValueItemClick(nil);
  end;
  
  // 标记为已修改
  FBasicInfoTab.Tag := 1; // 表示有未保存的更改
end;

procedure TfrmMain.ValueListEditorValidate(Sender: TObject; ACol, ARow: Integer; const KeyName, KeyValue: string);
begin
  // 这里可以添加验证逻辑，例如检查值的格式是否正确
  FormHelper.AddDebugText(meoDebug, Format('验证键值对: %s = %s', [KeyName, KeyValue]));
  
  // 此处不能修改KeyValue值，因为是常量
  // 如果验证失败，可以抛出异常
  // 例如：if (KeyName = 'Version') and (KeyValue <> '1.0') then
  //         raise Exception.Create('版本号必须为1.0');
  
  // 设置为已修改状态
  FBasicInfoTab.Tag := 1; // 表示有未保存的更改
end;

procedure TfrmMain.ValueListStringsValidate(Sender: TObject; var S: string);
begin
  // 字符串验证，可以用于更详细的输入验证
  FormHelper.AddDebugText(meoDebug, Format('验证字符串: %s', [S]));
  FBasicInfoTab.Tag := 1; // 表示有未保存的更改
  
  // 此处可以添加验证逻辑，如果验证失败，可以修改S的值或引发异常
  // 例如：if not ValidString(S) then S := '默认值';
end;

procedure TfrmMain.InitializeBasicInfoTab;
var
  PopupMenu: TPopupMenu;
  MenuItem: TMenuItem;
begin
  // 创建基础信息选项卡
  FBasicInfoTab := TTabSheet.Create(pcEditors);
  FBasicInfoTab.PageControl := pcEditors;
  FBasicInfoTab.Caption := '基础信息';
  FBasicInfoTab.Tag := -1; // 使用特殊Tag标记为系统选项卡
  
  // 创建值列表编辑器
  FValueListEditor := TValueListEditor.Create(FBasicInfoTab);
  FValueListEditor.Parent := FBasicInfoTab;
  FValueListEditor.Align := alClient;
  FValueListEditor.FixedCols := 1; // 第一列固定为键名
  FValueListEditor.Options := [goFixedVertLine, goFixedHorzLine, goVertLine,
                              goHorzLine, goColSizing, goEditing, goAlwaysShowEditor,
                              goThumbTracking];
  FValueListEditor.TitleCaptions.Clear;
  FValueListEditor.TitleCaptions.Add('配置项');
  FValueListEditor.TitleCaptions.Add('值');
  FValueListEditor.OnDblClick := ValueListEditorDblClick;
  // 设置验证事件
  FValueListEditor.OnValidate := ValueListEditorValidate;

  // 设置绘制事件，用于显示节标题
  FValueListEditor.OnDrawCell := ValueListEditorDrawCell;
  
  // 关联到公开的控件
  ValueListEditor1 := FValueListEditor;
  
  // 创建上下文菜单
  PopupMenu := TPopupMenu.Create(FValueListEditor);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '添加配置项';
  MenuItem.OnClick := AddValueItemClick;
  PopupMenu.Items.Add(MenuItem);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '添加新节';
  MenuItem.OnClick := AddSectionClick;
  PopupMenu.Items.Add(MenuItem);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '删除配置项';
  MenuItem.OnClick := DeleteValueItemClick;
  PopupMenu.Items.Add(MenuItem);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '重命名配置项';
  MenuItem.OnClick := RenameValueItemClick;
  PopupMenu.Items.Add(MenuItem);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '-'; // 分隔线
  PopupMenu.Items.Add(MenuItem);
  
  MenuItem := TMenuItem.Create(PopupMenu);
  MenuItem.Caption := '保存更改';
  MenuItem.OnClick := SaveValueItemsClick;
  PopupMenu.Items.Add(MenuItem);
  
  FValueListEditor.PopupMenu := PopupMenu;
  
  // 设置字体
  FValueListEditor.Font.Name := 'Microsoft YaHei UI';
  FValueListEditor.Font.Size := 10;
  
  // 默认将基础信息选项卡放在第一个位置
  FBasicInfoTab.PageIndex := 0;
  
  // 初始时显示基础信息选项卡，修改为可见
  FBasicInfoTab.TabVisible := True;
  
  FormHelper.AddDebugText(meoDebug, '基础信息选项卡创建完成，包含值列表编辑器');
end;

procedure TfrmMain.RenameValueItemClick(Sender: TObject);
var
  Row: Integer;
  OldKeyName, NewKeyName, Value: string;
begin
  if FValueListEditor.Row > 0 then // 第0行是标题行
  begin
    Row := FValueListEditor.Row;
    OldKeyName := FValueListEditor.Keys[Row];
    Value := FValueListEditor.Values[OldKeyName];
    
    if InputQuery('重命名配置项', '请输入新的配置项名称:', NewKeyName) then
    begin
      if NewKeyName.Trim <> '' then
      begin
        try
          // 删除旧配置项
          FValueListEditor.DeleteRow(Row);
          
          // 添加新配置项，保持原值
          FValueListEditor.InsertRow(NewKeyName, Value, True);
          
          FormHelper.AddDebugText(meoDebug, Format('重命名配置项: %s -> %s', [OldKeyName, NewKeyName]));
          
          // 设置为已修改状态
          FBasicInfoTab.Tag := 1; // 表示有未保存的更改
        except
          on E: Exception do
          begin
            FormHelper.AddDebugText(meoDebug, '重命名配置项时出错: ' + E.Message);
            ShowMessage('重命名失败: ' + E.Message);
          end;
        end;
      end;
    end;
  end;
end;

procedure TfrmMain.AddValueItemClick(Sender: TObject);
var
  KeyName, SelectedSection: string;
  RowIndex, i, SelectedRow: Integer;
  Key: string;
begin
  // 首先确定当前所在的节
  SelectedSection := 'General'; // 默认节
  SelectedRow := FValueListEditor.Row;
  
  // 向上查找最近的节标题
  if (SelectedRow > 0) then
  begin
    // 先检查当前行是否是节标题
    Key := FValueListEditor.Keys[SelectedRow];
    if (Key.StartsWith('[') and Key.EndsWith(']')) then
    begin
      SelectedSection := Copy(Key, 2, Length(Key) - 2); // 去掉方括号
    end
    else
    begin
      // 向上查找最近的节标题
      for i := SelectedRow downto 1 do
      begin
        Key := FValueListEditor.Keys[i];
        if (Key.StartsWith('[') and Key.EndsWith(']')) then
        begin
          SelectedSection := Copy(Key, 2, Length(Key) - 2); // 去掉方括号
          Break;
        end;
      end;
    end;
  end;
  
  if InputQuery('添加配置项', '请输入配置项名称:', KeyName) then
  begin
    if KeyName.Trim <> '' then
    begin
      // 检查是否已存在同名配置项
      RowIndex := -1;
      
      // 完整的键名包含节名
      if (SelectedSection <> '') then
        KeyName := SelectedSection + '.' + KeyName;
        
      if not FValueListEditor.FindRow(KeyName, RowIndex) then
      begin
        // 找到当前节的最后一个配置项，在其后插入
        var InsertPos := SelectedRow + 1;
        while (InsertPos < FValueListEditor.RowCount) and 
              not (FValueListEditor.Keys[InsertPos].StartsWith('[') and FValueListEditor.Keys[InsertPos].EndsWith(']')) do
          Inc(InsertPos);
        
        // 在当前位置插入新项
        FValueListEditor.InsertRow(KeyName, '', True);
        FormHelper.AddDebugText(meoDebug, '添加新配置项: ' + KeyName);
        
        // 设置为已修改状态
        FBasicInfoTab.Tag := 1; // 表示有未保存的更改
      end
      else
      begin
        ShowMessage('已存在同名配置项: ' + KeyName);
      end;
    end;
  end;
end;

procedure TfrmMain.DeleteValueItemClick(Sender: TObject);
var
  Row: Integer;
  KeyName: string;
begin
  if FValueListEditor.Row > 0 then // 第0行是标题行
  begin
    Row := FValueListEditor.Row;
    KeyName := FValueListEditor.Keys[Row];
    
    if MessageDlg('确定要删除配置项 "' + KeyName + '" 吗?', mtConfirmation, [mbYes, mbNo], 0) = mrYes then
    begin
      FValueListEditor.DeleteRow(Row);
      FormHelper.AddDebugText(meoDebug, '删除配置项: ' + KeyName);
      
      // 设置为已修改状态
      FBasicInfoTab.Tag := 1; // 表示有未保存的更改
    end;
  end;
end;

procedure TfrmMain.SaveValueItemsClick(Sender: TObject);
begin
  if FCurrentBasicConfigPath <> '' then
  begin
    SaveBasicInfoFromEditor(FCurrentBasicConfigPath);
    FormHelper.AddDebugText(meoDebug, '保存基础信息配置');
    
    // 清除修改标记
    FBasicInfoTab.Tag := 0;
  end;
end;

procedure TfrmMain.LoadBasicInfoToEditor(const ConfigPath: string);
var
  IniFile: TMemIniFile;
  JsonFile: TJSONObject;
  FileExt: string;
  Sections, Keys: TStringList;
  i, j: Integer;
  Section, Key, Value: string;
  FileContent: string;
  CurrentSection: string;
begin
  // 清空当前编辑器内容
  FValueListEditor.Strings.Clear;
  
  // 保存当前配置路径
  FCurrentBasicConfigPath := ConfigPath;
  
  // 根据文件扩展名确定配置类型
  FileExt := LowerCase(ExtractFileExt(ConfigPath));
  
  if FileExt = '.ini' then
  begin
    // 加载INI文件内容
    try
      // 显式使用 UTF-8 编码
      IniFile := TMemIniFile.Create(ConfigPath, TEncoding.UTF8);
      try
        Sections := TStringList.Create;
        Keys := TStringList.Create;
        try
          // 获取所有节
          IniFile.ReadSections(Sections);
          
          // 如果没有节，添加General节
          if Sections.Count = 0 then
            Sections.Add('General');
            
          for i := 0 to Sections.Count - 1 do
          begin
            Section := Sections[i];
            
            // 跳过注释或空节
            if (Section = '') or (Section.StartsWith(';')) then
              Continue;
              
            // 添加节标题
            try
              FValueListEditor.InsertRow('[' + Section + ']', '', True);
              FormHelper.AddDebugText(meoDebug, '添加节标题: ' + Section);
            except
              on E: Exception do
              begin
                FormHelper.AddDebugText(meoDebug, '添加节标题时出错: ' + Section + ' 错误: ' + E.Message);
              end;
            end;
            
            // 读取该节中的所有键
            Keys.Clear;
            IniFile.ReadSection(Section, Keys);
            
            for j := 0 to Keys.Count - 1 do
            begin
              Key := Keys[j];
              Value := IniFile.ReadString(Section, Key, '');
              
              // 添加到值列表编辑器，使用Section.Key作为键名
              try
                FValueListEditor.Values[Section + '.' + Key] := Value;
              except
                on E: Exception do
                begin
                  FormHelper.AddDebugText(meoDebug, '添加键值对时出错: ' + Section + '.' + Key + ' = ' + Value + 
                                          ' 错误: ' + E.Message);
                end;
              end;
            end;
          end;
          
          FormHelper.AddDebugText(meoDebug, '加载基础信息配置: ' + ConfigPath + ', 共' + IntToStr(FValueListEditor.RowCount - 1) + '个项目');
        finally
          Keys.Free;
          Sections.Free;
        end;
      finally
        IniFile.Free;
      end;
    except
      on E: Exception do
      begin
        FormHelper.AddDebugText(meoDebug, '加载基础信息配置失败: ' + E.Message);
        ShowMessage('加载配置失败: ' + E.Message);
      end;
    end;
  end
  else if FileExt = '.json' then
  begin
    // 加载JSON文件内容
    try
      if FileExists(ConfigPath) then
      begin
        try
          // 使用 UTF-8 编码读取文件
          FileContent := TFile.ReadAllText(ConfigPath, TEncoding.UTF8);
          JsonFile := TJSONObject(TJSONObject.ParseJSONValue(FileContent));
          
          if JsonFile <> nil then
          begin
            try
              // 添加默认节
              try
                FValueListEditor.InsertRow('[JSON根节点]', '', True);
              except
                on E: Exception do
                begin
                  FormHelper.AddDebugText(meoDebug, '添加JSON根节点标题时出错: ' + E.Message);
                end;
              end;
            
              // 遍历JSON对象的所有键值对
              for i := 0 to JsonFile.Count - 1 do
              begin
                Key := JsonFile.Pairs[i].JsonString.Value;
                
                // 将JSON值转换为字符串
                if JsonFile.Pairs[i].JsonValue is TJSONString then
                  Value := TJSONString(JsonFile.Pairs[i].JsonValue).Value
                else if JsonFile.Pairs[i].JsonValue is TJSONNumber then
                  Value := TJSONNumber(JsonFile.Pairs[i].JsonValue).ToString
                else if JsonFile.Pairs[i].JsonValue is TJSONBool then
                  Value := BoolToStr(TJSONBool(JsonFile.Pairs[i].JsonValue).AsBoolean, True)
                else
                  Value := JsonFile.Pairs[i].JsonValue.ToString;
                
                // 添加到值列表编辑器
                try
                  FValueListEditor.Values['JSON根节点.' + Key] := Value;
                except
                  on E: Exception do
                  begin
                    FormHelper.AddDebugText(meoDebug, '添加JSON键值对时出错: ' + Key + ' = ' + Value + 
                                            ' 错误: ' + E.Message);
                  end;
                end;
              end;
              
              FormHelper.AddDebugText(meoDebug, '加载基础信息配置: ' + ConfigPath + ', 共' + IntToStr(FValueListEditor.RowCount - 1) + '个项目');
            finally
              JsonFile.Free;
            end;
          end;
        except
          on E: Exception do
          begin
            FormHelper.AddDebugText(meoDebug, '解析JSON失败: ' + E.Message);
            ShowMessage('解析JSON失败: ' + E.Message);
          end;
        end;
      end;
    except
      on E: Exception do
      begin
        FormHelper.AddDebugText(meoDebug, '加载基础信息配置失败: ' + E.Message);
        ShowMessage('加载配置失败: ' + E.Message);
      end;
    end;
  end;
  
  // 显示基础信息选项卡
  FBasicInfoTab.TabVisible := True;
  pcEditors.ActivePage := FBasicInfoTab;
end;

procedure TfrmMain.SaveBasicInfoFromEditor(const ConfigPath: string);
var
  IniFile: TMemIniFile;
  JsonFile: TJSONObject;
  FileExt: string;
  i: Integer;
  Key, Value, Section, KeyName: string;
  P: Integer;
  IntValue: Integer;
  FloatValue: Extended;
  CurrentSection: string;
begin
  // 根据文件扩展名确定配置类型
  FileExt := LowerCase(ExtractFileExt(ConfigPath));
  
  FormHelper.AddDebugText(meoDebug, '开始保存配置到: ' + ConfigPath);
  
  if FileExt = '.ini' then
  begin
    // 保存到INI文件
    try
      // 使用 UTF-8 编码
      IniFile := TMemIniFile.Create(ConfigPath, TEncoding.UTF8);
      try
        // 清空原有内容
        IniFile.Clear;
        
        CurrentSection := 'General'; // 默认节
        
        // 保存值列表编辑器中的内容
        for i := 1 to FValueListEditor.RowCount - 1 do // 跳过标题行
        begin
          try
            Key := FValueListEditor.Keys[i];
            
            // 检查是否是节标题
            if (Key.StartsWith('[') and Key.EndsWith(']')) then
            begin
              // 更新当前节
              CurrentSection := Copy(Key, 2, Length(Key) - 2);
              FormHelper.AddDebugText(meoDebug, '处理节: ' + CurrentSection);
              Continue; // 跳过节标题行
            end;
            
            Value := FValueListEditor.Values[Key];
            
            FormHelper.AddDebugText(meoDebug, Format('保存键值对: %s = %s', [Key, Value]));
            
            // 如果键名中包含点号，表示格式为Section.Key
            P := Pos('.', Key);
            if P > 0 then
            begin
              Section := Copy(Key, 1, P - 1);
              KeyName := Copy(Key, P + 1, Length(Key));
              IniFile.WriteString(Section, KeyName, Value);
            end
            else
            begin
              // 没有点号，使用当前节
              IniFile.WriteString(CurrentSection, Key, Value);
            end;
          except
            on E: Exception do
            begin
              FormHelper.AddDebugText(meoDebug, '保存键值对时出错: ' + Key + ' 错误: ' + E.Message);
            end;
          end;
        end;
        
        // 保存到文件
        IniFile.UpdateFile;
        FormHelper.AddDebugText(meoDebug, '保存基础信息配置成功: ' + ConfigPath);
      finally
        IniFile.Free;
      end;
    except
      on E: Exception do
      begin
        FormHelper.AddDebugText(meoDebug, '保存基础信息配置失败: ' + E.Message);
        ShowMessage('保存配置失败: ' + E.Message);
      end;
    end;
  end
  else if FileExt = '.json' then
  begin
    // 保存到JSON文件
    try
      JsonFile := TJSONObject.Create;
      try
        // 保存值列表编辑器中的内容
        for i := 1 to FValueListEditor.RowCount - 1 do // 跳过标题行
        begin
          try
            Key := FValueListEditor.Keys[i];
            
            // 跳过节标题
            if (Key.StartsWith('[') and Key.EndsWith(']')) then
              Continue;
              
            Value := FValueListEditor.Values[Key];
            
            FormHelper.AddDebugText(meoDebug, Format('保存JSON键值对: %s = %s', [Key, Value]));
            
            // 如果键名中包含点号，只保留点号后面的部分作为JSON的键
            P := Pos('.', Key);
            if P > 0 then
              Key := Copy(Key, P + 1, Length(Key));
            
            // 尝试将值解析为适当的JSON类型
            if (Value = 'True') or (Value = 'False') then
              JsonFile.AddPair(Key, TJSONBool.Create(Value = 'True'))
            else if TryStrToInt(Value, IntValue) then
              JsonFile.AddPair(Key, TJSONNumber.Create(IntValue))
            else if TryStrToFloat(Value, FloatValue) then
              JsonFile.AddPair(Key, TJSONNumber.Create(FloatValue))
            else
              JsonFile.AddPair(Key, Value);
          except
            on E: Exception do
            begin
              FormHelper.AddDebugText(meoDebug, '保存JSON键值对时出错: ' + Key + ' 错误: ' + E.Message);
            end;
          end;
        end;
        
        // 保存到文件，使用 UTF-8 编码
        TFile.WriteAllText(ConfigPath, JsonFile.ToJSON, TEncoding.UTF8);
        FormHelper.AddDebugText(meoDebug, '保存基础信息配置成功: ' + ConfigPath);
      finally
        JsonFile.Free;
      end;
    except
      on E: Exception do
      begin
        FormHelper.AddDebugText(meoDebug, '保存基础信息配置失败: ' + E.Message);
        ShowMessage('保存配置失败: ' + E.Message);
      end;
    end;
  end;
  
  // 更新界面状态
  FBasicInfoTab.Tag := 0; // 清除修改标记
  ShowMessage('配置已保存。');
end;

procedure TfrmMain.cbbThemeChange(Sender: TObject);
begin
  if cbbTheme.ItemIndex >= 0 then
  begin
    FormHelper.AddDebugText(meoDebug, '用户选择了主题: ' + cbbTheme.Items[cbbTheme.ItemIndex]);
    ApplyTheme(cbbTheme.Items[cbbTheme.ItemIndex]);
  end;
end;

procedure TfrmMain.LoadAvailableThemes;
var
  StyleNames: TArray<string>;
  i: Integer;
  CurrentStyle: string;
  IniFile: TIniFile;
  SavedTheme: string;
begin
  try
    // 获取所有可用样式名称
    StyleNames := TStyleManager.StyleNames;
    
    FormHelper.AddDebugText(meoDebug, '发现 ' + IntToStr(Length(StyleNames)) + ' 个可用主题');
    
    // 添加到组合框
    cbbTheme.Items.Clear;
    for i := 0 to High(StyleNames) do
    begin
      cbbTheme.Items.Add(StyleNames[i]);
      FormHelper.AddDebugText(meoDebug, '添加主题: ' + StyleNames[i]);
    end;
    
    // 先从配置文件中获取保存的主题
    IniFile := TIniFile.Create(ChangeFileExt(Application.ExeName, '.ini'));
    try
      SavedTheme := IniFile.ReadString('Settings', 'Theme', '');
      
      if (SavedTheme <> '') and (cbbTheme.Items.IndexOf(SavedTheme) >= 0) then
      begin
        FormHelper.AddDebugText(meoDebug, '从配置文件加载保存的主题: ' + SavedTheme);
        cbbTheme.ItemIndex := cbbTheme.Items.IndexOf(SavedTheme);
        
        // 应用保存的主题
        ApplyTheme(SavedTheme);
      end
      else
      begin
        // 如果没有保存的主题或无法加载，使用当前活动的样式
        CurrentStyle := TStyleManager.ActiveStyle.Name;
        FormHelper.AddDebugText(meoDebug, '当前活动主题: ' + CurrentStyle);
        
        cbbTheme.ItemIndex := cbbTheme.Items.IndexOf(CurrentStyle);
        if cbbTheme.ItemIndex < 0 then
        begin
          // 如果当前样式不在列表中，默认使用Windows或第一个可用主题
          cbbTheme.ItemIndex := cbbTheme.Items.IndexOf('Windows');
          
          if cbbTheme.ItemIndex < 0 then
          begin
            // 如果Windows样式也不在列表中，使用第一个可用主题
            if cbbTheme.Items.Count > 0 then
            begin
              cbbTheme.ItemIndex := 0;
              FormHelper.AddDebugText(meoDebug, '使用默认主题: ' + cbbTheme.Items[0]);
            end;
          end
          else
          begin
            FormHelper.AddDebugText(meoDebug, '使用Windows主题');
          end;
        end;
      end;
    finally
      IniFile.Free;
    end;
    
    FormHelper.AddDebugText(meoDebug, '主题加载完成');
  except
    on E: Exception do
    begin
      FormHelper.AddDebugText(meoDebug, '加载主题时出错: ' + E.Message);
    end;
  end;
end;

procedure TfrmMain.ApplyTheme(const ThemeName: string);
var
  IniFile: TIniFile;
begin
  try
    if not TStyleManager.TrySetStyle(ThemeName) then
    begin
      FormHelper.AddDebugText(meoDebug, '主题应用失败: ' + ThemeName + ' 可能不存在');
      Exit;
    end;
    
    FormHelper.AddDebugText(meoDebug, '主题应用成功: ' + ThemeName);
    
    // 保存主题设置到配置文件
    try
      IniFile := TIniFile.Create(ExtractFilePath(Application.ExeName) + 'ConfigManager.ini');
      try
        IniFile.WriteString('Settings', 'Theme', ThemeName);
        FormHelper.AddDebugText(meoDebug, '主题设置已保存到INI文件: ' + ThemeName);
      finally
        IniFile.Free;
      end;
    except
      on E: Exception do
      begin
        FormHelper.AddDebugText(meoDebug, '保存主题设置时出错: ' + E.Message);
      end;
    end;
  except
    on E: Exception do
    begin
      FormHelper.AddDebugText(meoDebug, '应用主题时出错: ' + E.Message);
      ShowMessage('应用主题时出错: ' + E.Message);
    end;
  end;
end;

procedure TfrmMain.AddSectionClick(Sender: TObject);
var
  NewSectionName: string;
begin
  if InputQuery('添加新节', '请输入新节名称:', NewSectionName) then
  begin
    if NewSectionName.Trim <> '' then
    begin
      try
        // 添加新节，使用方括号标记
        FValueListEditor.InsertRow('[' + NewSectionName + ']', '', True);
        FormHelper.AddDebugText(meoDebug, '添加新节: ' + NewSectionName);
        
        // 设置为已修改状态
        FBasicInfoTab.Tag := 1; // 表示有未保存的更改
      except
        on E: Exception do
        begin
          FormHelper.AddDebugText(meoDebug, '添加新节时出错: ' + E.Message);
          ShowMessage('添加新节失败: ' + E.Message);
        end;
      end;
    end;
  end;
end;

procedure TfrmMain.ValueListEditorDrawCell(Sender: TObject; ACol, ARow: Integer; Rect: TRect; State: TGridDrawState);
var
  Value, SectionName: string;
  Grid: TValueListEditor;
  P: Integer;
  TextRect: TRect;
  OldBrushColor: TColor;
  IsSection: Boolean;
begin
  Grid := Sender as TValueListEditor;
  
  // 为标题行和数据行应用不同的样式
  if ARow = 0 then
  begin
    // 标题行样式
    Grid.Canvas.Brush.Color := clBtnFace;
    Grid.Canvas.Font.Style := [fsBold];
    Grid.Canvas.FillRect(Rect);
    
    // 绘制标题文本
    TextRect := Rect;
    InflateRect(TextRect, -2, -2);
    if ACol = 0 then
      DrawText(Grid.Canvas.Handle, PChar(Grid.TitleCaptions[0]), -1, TextRect, DT_VCENTER or DT_SINGLELINE or DT_LEFT)
    else if ACol = 1 then
      DrawText(Grid.Canvas.Handle, PChar(Grid.TitleCaptions[1]), -1, TextRect, DT_VCENTER or DT_SINGLELINE or DT_LEFT);
      
    Exit; // 不再执行后续代码
  end;
  
  // 非标题行的处理
  if ARow > 0 then
  begin
    // 保存原来的画刷颜色
    OldBrushColor := Grid.Canvas.Brush.Color;
    
    // 检查是否是节标题
    Value := Grid.Keys[ARow];
    
    // 判断是否是节的标记项
    IsSection := False;
    if (ACol = 0) and (Value <> '') then
    begin
      P := Pos('.', Value);
      if P = 0 then
      begin
        // 当没有点号时，查找该行是否在值列表编辑器中有[Section]这样的格式表示节
        if (Value.StartsWith('[') and Value.EndsWith(']')) then
        begin
          IsSection := True;
          SectionName := Copy(Value, 2, Length(Value) - 2); // 提取节名（去掉方括号）
          
          // 绘制节标题行
          Grid.Canvas.Brush.Color := $00E6FFEE; // 浅绿色背景
          Grid.Canvas.Font.Style := [fsBold];
          Grid.Canvas.Font.Color := clNavy;
          Grid.Canvas.FillRect(Rect);
          
          // 绘制节标题文本
          TextRect := Rect;
          InflateRect(TextRect, -2, -2);
          DrawText(Grid.Canvas.Handle, PChar(SectionName), -1, TextRect, DT_VCENTER or DT_SINGLELINE or DT_LEFT);
          
          // 如果是第二列，清空该列（节标题行不需要值）
          if ACol = 1 then
          begin
            Grid.Canvas.Brush.Color := $00E6FFEE;
            Grid.Canvas.FillRect(Rect);
          end;
          
          Exit; // 处理完节标题行后直接退出
        end;
      end;
    end;
    
    // 默认样式恢复
    if not IsSection then
    begin
      // 为选中行应用不同的样式
      if (gdSelected in State) or (gdFocused in State) then
      begin
        // 调用默认的单元格绘制方法
        Grid.DefaultDrawCell(ACol, ARow, Rect, State);
      end
      else
      begin
        // 为交替行应用不同的背景颜色
        if Odd(ARow) then
          Grid.Canvas.Brush.Color := $00F5F5F5 // 浅灰色
        else
          Grid.Canvas.Brush.Color := clWhite;
          
        Grid.Canvas.FillRect(Rect);
        
        // 绘制单元格文本
        TextRect := Rect;
        InflateRect(TextRect, -2, -2);
        
        if ACol = 0 then
        begin
          // 键列
          DrawText(Grid.Canvas.Handle, PChar(Grid.Keys[ARow]), -1, TextRect, DT_VCENTER or DT_SINGLELINE or DT_LEFT);
        end
        else if ACol = 1 then
        begin
          // 值列
          DrawText(Grid.Canvas.Handle, PChar(Grid.Values[Grid.Keys[ARow]]), -1, TextRect, DT_VCENTER or DT_SINGLELINE or DT_LEFT);
        end;
      end;
    end;
  end;
end;

procedure TfrmMain.LoadSectionToEditor(const ConfigPath, SectionName: string);
var
  FileExt: string;
  IniFile: TMemIniFile;
  JsonFile: TJSONObject;
  Keys: TStringList;
  i: Integer;
  Key, Value: string;
  FileContent: string;
  JsonProperty: TJSONPair;
  EncodingUsed: TEncoding;
  EncodingOptions: array of TEncoding;
  SuccessfullyLoaded: Boolean;
begin
  try
    FormHelper.AddDebugText(meoDebug, '===== 开始加载节内容 =====');
    
    // 清空当前编辑器内容
    FValueListEditor.Strings.Clear;
    
    // 保存当前配置路径
    FCurrentBasicConfigPath := ConfigPath;
    
    // 根据文件扩展名确定配置类型
    FileExt := LowerCase(ExtractFileExt(ConfigPath));
    
    FormHelper.AddDebugText(meoDebug, '加载文件: ' + ConfigPath);
    FormHelper.AddDebugText(meoDebug, '节名: ' + SectionName + ' (字节长度: ' + IntToStr(ByteLength(SectionName)) + ')');
    
    if FileExt = '.ini' then
    begin
      // 定义尝试的编码顺序
      EncodingOptions := [TEncoding.UTF8, TEncoding.Unicode, TEncoding.Default, TEncoding.ASCII];
      SuccessfullyLoaded := False;
      
      // 尝试使用不同的编码加载INI文件
      for EncodingUsed in EncodingOptions do
      begin
        if SuccessfullyLoaded then
          Break;
          
        FormHelper.AddDebugText(meoDebug, '尝试使用编码: ' + EncodingUsed.ClassName);
        
        try
          IniFile := TMemIniFile.Create(ConfigPath, EncodingUsed);
          try
            Keys := TStringList.Create;
            try
              // 添加节标题
              try
                var SectionHeader := '[' + SectionName + ']';
                FormHelper.AddDebugText(meoDebug, '正在添加节标题: ' + SectionHeader);
                
                FValueListEditor.InsertRow(SectionHeader, '', True);
                FormHelper.AddDebugText(meoDebug, '成功添加节标题');
                
                // 读取该节中的所有键
                IniFile.ReadSection(SectionName, Keys);
                
                FormHelper.AddDebugText(meoDebug, '节包含 ' + IntToStr(Keys.Count) + ' 个键');
                
                for i := 0 to Keys.Count - 1 do
                begin
                  Key := Keys[i];
                  Value := IniFile.ReadString(SectionName, Key, '');
                  
                  // 添加到值列表编辑器
                  try
                    var FullKey := SectionName + '.' + Key;
                    FormHelper.AddDebugText(meoDebug, '添加键值对: ' + FullKey + ' = ' + Value);
                    
                    FValueListEditor.Values[FullKey] := Value;
                  except
                    on E: Exception do
                    begin
                      FormHelper.AddDebugText(meoDebug, '添加键值对时出错: ' + E.Message);
                      // 继续尝试添加其他键值对
                    end;
                  end;
                end;
                
                SuccessfullyLoaded := True;
                FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码成功加载节内容');
              except
                on E: Exception do
                begin
                  FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码添加节标题时出错: ' + E.Message);
                  // 将在下一次循环中尝试其他编码
                end;
              end;
            finally
              Keys.Free;
            end;
          finally
            IniFile.Free;
          end;
        except
          on E: Exception do
          begin
            FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码加载文件时出错: ' + E.Message);
            // 将在下一次循环中尝试其他编码
          end;
        end;
      end;
      
      if not SuccessfullyLoaded then
      begin
        FormHelper.AddDebugText(meoDebug, '所有编码尝试均失败，无法加载节内容');
        ShowMessage('无法加载配置节: ' + SectionName + '。可能包含不支持的字符编码。');
      end;
    end
    else if FileExt = '.json' then
    begin
      // 尝试使用不同的编码加载JSON文件
      EncodingOptions := [TEncoding.UTF8, TEncoding.Unicode, TEncoding.Default];
      SuccessfullyLoaded := False;
      
      for EncodingUsed in EncodingOptions do
      begin
        if SuccessfullyLoaded then
          Break;
          
        FormHelper.AddDebugText(meoDebug, '尝试使用编码: ' + EncodingUsed.ClassName + ' 加载JSON文件');
        
        try
          if FileExists(ConfigPath) then
          begin
            try
              // 使用指定编码读取文件
              FileContent := TFile.ReadAllText(ConfigPath, EncodingUsed);
              JsonFile := TJSONObject(TJSONObject.ParseJSONValue(FileContent));
              
              if JsonFile <> nil then
              begin
                try
                  // 添加JSON根节点标题
                  try
                    FValueListEditor.InsertRow('[JSON根节点]', '', True);
                    FormHelper.AddDebugText(meoDebug, '添加JSON根节点标题成功');
                  except
                    on E: Exception do
                    begin
                      FormHelper.AddDebugText(meoDebug, '添加JSON根节点标题时出错: ' + E.Message);
                      Continue; // 尝试下一种编码
                    end;
                  end;
                
                  // 遍历JSON对象的所有键值对
                  for i := 0 to JsonFile.Count - 1 do
                  begin
                    JsonProperty := JsonFile.Pairs[i];
                    Key := JsonProperty.JsonString.Value;
                    
                    // 将JSON值转换为字符串
                    if JsonProperty.JsonValue is TJSONString then
                      Value := TJSONString(JsonProperty.JsonValue).Value
                    else if JsonProperty.JsonValue is TJSONNumber then
                      Value := TJSONNumber(JsonProperty.JsonValue).ToString
                    else if JsonProperty.JsonValue is TJSONBool then
                      Value := BoolToStr(TJSONBool(JsonProperty.JsonValue).AsBoolean, True)
                    else if JsonProperty.JsonValue is TJSONObject then
                      Value := '[Object]'
                    else if JsonProperty.JsonValue is TJSONArray then
                      Value := '[Array]'
                    else
                      Value := JsonProperty.JsonValue.ToString;
                    
                    // 添加到值列表编辑器
                    try
                      var FullKey := 'JSON根节点.' + Key;
                      FormHelper.AddDebugText(meoDebug, '添加JSON键值对: ' + FullKey);
                      
                      FValueListEditor.Values[FullKey] := Value;
                    except
                      on E: Exception do
                      begin
                        FormHelper.AddDebugText(meoDebug, '添加JSON键值对时出错: ' + E.Message);
                        // 继续尝试添加其他键值对
                      end;
                    end;
                  end;
                  
                  SuccessfullyLoaded := True;
                  FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码成功加载JSON内容');
                finally
                  JsonFile.Free;
                end;
              end;
            except
              on E: Exception do
              begin
                FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码解析JSON失败: ' + E.Message);
                // 将在下一次循环中尝试其他编码
              end;
            end;
          end;
        except
          on E: Exception do
          begin
            FormHelper.AddDebugText(meoDebug, '使用 ' + EncodingUsed.ClassName + ' 编码加载JSON内容失败: ' + E.Message);
            // 将在下一次循环中尝试其他编码
          end;
        end;
      end;
      
      if not SuccessfullyLoaded then
      begin
        FormHelper.AddDebugText(meoDebug, '所有编码尝试均失败，无法加载JSON内容');
        ShowMessage('无法加载JSON配置。可能包含不支持的字符编码。');
      end;
    end;
    
    // 显示基础信息选项卡
    FBasicInfoTab.TabVisible := True;
    pcEditors.ActivePage := FBasicInfoTab;
    
    FormHelper.AddDebugText(meoDebug, '===== 节内容加载完成 =====');
  except
    on E: Exception do
    begin
      FormHelper.AddDebugText(meoDebug, '加载节时出现未处理的异常: ' + E.Message);
      ShowMessage('出现错误: ' + E.Message);
    end;
  end;
end;

end. 