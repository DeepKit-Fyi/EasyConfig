procedure TfrmMain.FileListBox1DblClick(Sender: TObject);
var
  FileName: string;
  FileExt: string;
  ConfigType: string;
begin
  if FileListBox1.ItemIndex < 0 then
    Exit;
  
  FileName := FileListBox1.Directory + '\' + FileListBox1.Items[FileListBox1.ItemIndex];
  FileExt := LowerCase(ExtractFileExt(FileName));
  
  // 确定配置类型
  if FileExt = '.ini' then
    ConfigType := 'INI'
  else if FileExt = '.json' then
    ConfigType := 'JSON'
  else
    Exit; // 不支持的文件类型
  
  // 打开配置编辑器
  OpenConfigEditor(ConfigType, FileName);
  
  // 记录调试信息
  FormHelper.AddDebugText(meoDebug, '从文件列表打开配置: ' + FileName);
end;

