procedure TfrmMain.pmTreeOpenClick(Sender: TObject);
var
  Node: TTreeNode;
  Data: PConfigPageInfo;
begin
  Node := tvConfig.Selected;
  if (Node <> nil) and (Node.Level > 0) and (Node.Data <> nil) then
  begin
    Data := PConfigPageInfo(Node.Data);
    OpenConfigEditor(Data^.ConfigType, Data^.ConfigPath);
  end;
end;

procedure TfrmMain.pmTreeNewClick(Sender: TObject);
var
  NodeData: PNodeData;
  NewFileName, CategoryName, ConfigType, ConfigPath: string;
begin
  NodeData := GetSelectedNodeData(tvConfig);
  if (NodeData <> nil) and (NodeData.NodeType = ntCategory) then
  begin
    CategoryName := NodeData.CategoryName;
    
    // 显示新建配置文件对话框
    if InputQuery('新建配置', '请输入配置文件名称（不含扩展名）:', NewFileName) then
    begin
      // 创建新的INI配置文件，确保config目录已存在
      if not DirectoryExists('config') then
      begin
        ShowMessage('配置目录不存在：config，请确保该目录存在于应用程序根目录下。');
        Exit;
      end;
        
      ConfigType := 'INI';
      ConfigPath := 'config\' + NewFileName + '.ini';
      
      // 创建空白配置文件
      with TStringList.Create do
      try
        Add('; ' + CategoryName + ' - 配置文件');
        Add('; 创建日期: ' + FormatDateTime('yyyy-mm-dd', Now));
        Add('');
        Add('[General]');
        Add('Version=1.0');
        Add('Description=' + NewFileName);
        SaveToFile(ConfigPath);
      finally
        Free;
      end;
      
      // 添加到树型视图
      AddPropertyEntityToCategory(tvConfig, CategoryName, NewFileName + '.ini', ConfigType, ConfigPath);
      
      // 打开编辑器
      OpenConfigEditor(ConfigType, ConfigPath);
    end;
  end;
end;

procedure TfrmMain.pmTreeDeleteClick(Sender: TObject);
var
  Node: TTreeNode;
  Data: PConfigPageInfo;
  ConfigPath: string;
  Index: Integer;
begin
  Node := tvConfig.Selected;
  if (Node = nil) or (Node.Level = 0) or (Node.Data = nil) then
    Exit;
    
  Data := PConfigPageInfo(Node.Data);
  ConfigPath := Data^.ConfigPath;
  
  // 确认删除
  if MessageDlg('确定要删除配置文件 "' + ExtractFileName(ConfigPath) + '" 吗？', 
               mtConfirmation, [mbYes, mbNo], 0) = mrNo then
    Exit;
    
  // 如果文件已打开，先关闭
  Index := FindOpenPage(ConfigPath);
  if Index >= 0 then
    CloseConfigPage(Index);
    
  // 删除文件
  try
    if DeleteFile(ConfigPath) then
    begin
      // 删除树节点
      Node.Free;
      ShowMessage('配置文件已删除');
    end
    else
    begin
      ShowMessage('无法删除配置文件');
    end;
  except
    on E: Exception do
    begin
      ShowMessage('删除配置文件时出错：' + E.Message);
    end;
  end;
end;

procedure TfrmMain.pmTreeRenameClick(Sender: TObject);
var
  Node: TTreeNode;
  Data: PConfigPageInfo;
  OldPath, NewPath, NewName: string;
  Index: Integer;
begin
  Node := tvConfig.Selected;
  if (Node = nil) or (Node.Level = 0) or (Node.Data = nil) then
    Exit;
    
  Data := PConfigPageInfo(Node.Data);
  OldPath := Data^.ConfigPath;
  
  // 获取新文件名
  NewName := InputBox('重命名配置文件', '请输入新文件名：', ExtractFileName(OldPath));
  
  if (NewName = '') or (NewName = ExtractFileName(OldPath)) then
    Exit;
    
  // 构造新路径
  NewPath := ExtractFilePath(OldPath) + NewName;
  
  // 如果文件已打开，先关闭
  Index := FindOpenPage(OldPath);
  if Index >= 0 then
    CloseConfigPage(Index);
    
  // 重命名文件
  try
    if RenameFile(OldPath, NewPath) then
    begin
      // 更新节点文本和数据
      Node.Text := NewName;
      Data^.Title := NewName;
      Data^.ConfigPath := NewPath;
      
      ShowMessage('配置文件已重命名');
    end
    else
    begin
      ShowMessage('无法重命名配置文件');
    end;
  except
    on E: Exception do
    begin
      ShowMessage('重命名配置文件时出错：' + E.Message);
    end;
  end;
end;

