{$R *.dfm}

{ TfrmMain }

procedure TfrmMain.FormCreate(Sender: TObject);
var
  Separator1, Separator2: TPanel;
  ExpandCollapseBtn: TSkSvg;
begin
  // 设置默认样式，避免'Aqua Light Slate'不存在的错误
  FormHelper.SetApplicationStyle('Windows', nil);

  // 初始化调试和输出区域
  meoDebug.Clear;
  meoOutput.Clear;

  // 设置显示中文的正确编码
  meoDebug.Font.Name := 'Microsoft YaHei UI';
  meoOutput.Font.Name := 'Microsoft YaHei UI';
  
  // 创建主题选择组合框
  lblTheme := TLabel.Create(Self);
  lblTheme.Parent := pnlTop;
  lblTheme.Caption := '主题:';
  lblTheme.Align := alRight;
  lblTheme.AlignWithMargins := True;
  lblTheme.Layout := tlCenter;
  lblTheme.Margins.Right := 5;
  lblTheme.Margins.Top := 15;
  
  cbbTheme := TComboBox.Create(Self);
  cbbTheme.Parent := pnlTop;
  cbbTheme.Width := 150;
  cbbTheme.Align := alRight;
  cbbTheme.AlignWithMargins := True;
  cbbTheme.Margins.Right := 10;
  cbbTheme.Margins.Top := 15;
  cbbTheme.Style := csDropDownList;
  cbbTheme.OnChange := cbbThemeChange;
  
  // 在代码中创建toggle按钮
  btnSvgToggle := TSkSvg.Create(Self);
  btnSvgToggle.Parent := pnlTop;
  btnSvgToggle.AlignWithMargins := True;
  btnSvgToggle.Margins.Left := 5;
  btnSvgToggle.Margins.Right := 5;
  btnSvgToggle.Width := 50;
  btnSvgToggle.Height := 51;
  btnSvgToggle.Hint := '显示/隐藏空分类';
  btnSvgToggle.ShowHint := True;
  btnSvgToggle.OnClick := btnSvgToggleClick;
  
  // 创建展开/收缩按钮
  ExpandCollapseBtn := TSkSvg.Create(Self);
  ExpandCollapseBtn.Parent := pnlTop;
  ExpandCollapseBtn.AlignWithMargins := True;
  ExpandCollapseBtn.Margins.Left := 5;
  ExpandCollapseBtn.Margins.Right := 5;
  ExpandCollapseBtn.Width := 50;
  ExpandCollapseBtn.Height := 51;
  ExpandCollapseBtn.Hint := '全部展开/收缩';
  ExpandCollapseBtn.ShowHint := True;
  ExpandCollapseBtn.OnClick := btnSvgExpandCollapseClick;
  ExpandCollapseBtn.Name := 'btnSvgExpandCollapse';
  
  // 创建分隔线1
  Separator1 := TPanel.Create(Self);
  Separator1.Parent := pnlTop;
  Separator1.Width := 2;
  Separator1.BevelOuter := bvNone;
  Separator1.Color := clGray;
  Separator1.Height := 51;
  Separator1.Name := 'pnlSeparator1';
  Separator1.AlignWithMargins := True;
  Separator1.Margins.Left := 10;
  Separator1.Margins.Right := 10;
  Separator1.Align := alLeft;
  
  // 创建分隔线2
  Separator2 := TPanel.Create(Self);
  Separator2.Parent := pnlTop;
  Separator2.Width := 2;
  Separator2.BevelOuter := bvNone;
  Separator2.Color := clGray;
  Separator2.Height := 51;
  Separator2.Name := 'pnlSeparator2';
  Separator2.AlignWithMargins := True;
  Separator2.Margins.Left := 10;
  Separator2.Margins.Right := 10;
  Separator2.Align := alLeft;
  
  // 重新排序按钮 - 配置文件管理
  btnSvgOpen.Align := alNone;
  btnSvgSaveAs.Align := alNone;
  btnSvgDelete.Align := alNone;
  btnSvgSave.Align := alNone;
  btnSvgRefresh.Align := alNone;
  
  // 子节点管理
  btnSvgNewNode.Align := alNone;
  btnSvgRemoveNode.Align := alNone;
  btnSvgEditNode.Align := alNone;
  btnSvgToggle.Align := alNone;
  ExpandCollapseBtn.Align := alNone;
  
  // 退出按钮
  btnSvgExit.Align := alNone;
  
  // 重新设置按钮顺序
  // 第一组：配置文件管理
  btnSvgOpen.Left := 3;
  btnSvgOpen.Top := 3;
  btnSvgOpen.Align := alLeft;
  
  btnSvgSaveAs.Left := btnSvgOpen.Left + btnSvgOpen.Width + 5;
  btnSvgSaveAs.Top := 3;
  btnSvgSaveAs.Align := alLeft;
  
  btnSvgDelete.Left := btnSvgSaveAs.Left + btnSvgSaveAs.Width + 5;
  btnSvgDelete.Top := 3;
  btnSvgDelete.Align := alLeft;
  
  btnSvgSave.Left := btnSvgDelete.Left + btnSvgDelete.Width + 5;
  btnSvgSave.Top := 3;
  btnSvgSave.Align := alLeft;
  
  btnSvgRefresh.Left := btnSvgSave.Left + btnSvgSave.Width + 5;
  btnSvgRefresh.Top := 3;
  btnSvgRefresh.Align := alLeft;
  
  // 分隔线1
  Separator1.Left := btnSvgRefresh.Left + btnSvgRefresh.Width + 10;
  Separator1.Top := 3;
  
  // 第二组：子节点管理
  btnSvgNewNode.Left := Separator1.Left + Separator1.Width + 10;
  btnSvgNewNode.Top := 3;
  btnSvgNewNode.Align := alLeft;
  
  btnSvgRemoveNode.Left := btnSvgNewNode.Left + btnSvgNewNode.Width + 5;
  btnSvgRemoveNode.Top := 3;
  btnSvgRemoveNode.Align := alLeft;
  
  btnSvgEditNode.Left := btnSvgRemoveNode.Left + btnSvgRemoveNode.Width + 5;
  btnSvgEditNode.Top := 3;
  btnSvgEditNode.Align := alLeft;
  
  btnSvgToggle.Left := btnSvgEditNode.Left + btnSvgEditNode.Width + 5;
  btnSvgToggle.Top := 3;
  btnSvgToggle.Align := alLeft;
  
  ExpandCollapseBtn.Left := btnSvgToggle.Left + btnSvgToggle.Width + 5;
  ExpandCollapseBtn.Top := 3;
  ExpandCollapseBtn.Align := alLeft;
  
  // 分隔线2
  Separator2.Left := ExpandCollapseBtn.Left + ExpandCollapseBtn.Width + 10;
  Separator2.Top := 3;
  
  // 退出按钮 - 左对齐（实际上还是在右边，但是靠近Separator2）
  btnSvgExit.Left := Separator2.Left + Separator2.Width + 10;
  btnSvgExit.Top := 3;
  btnSvgExit.Align := alLeft;
  
  // 确保config目录存在并初始化
  InitConfigDirectory(meoDebug);
  
  // 创建页面列表
  FOpenPages := TList.Create;
  
  // 初始化基础信息选项卡
  FormHelper.AddDebugText(meoDebug, '正在初始化基础信息编辑选项卡...');
  InitializeBasicInfoTab;
  FormHelper.AddDebugText(meoDebug, '基础信息编辑选项卡初始化完成');
  
  // 加载应用程序设置
  LoadApplicationSettings(Self, meoDebug);
  
  // 初始化配置管理器
  FConfigManager := InitConfigManager('config\start.ini', meoDebug);
  
  // 初始化文件列表框
  InitFileListBox(FileListBox1, GetCurrentDir + '\config');
  
  // 初始化SVG按钮图标和提示
  InitSvgButtons(Self);
  
  // 加载可用主题
  LoadAvailableThemes;
  
  // 记录启动信息
  FormHelper.AddDebugText(meoDebug, '配置编辑器启动 - ' + FormatDateTime('yyyy-mm-dd hh:nn:ss', Now));
  
  // 初始化树视图并更新状态栏
  InitializeTree;
  UpdateStatusBar;
  
  // 确保值列表编辑器和标签页是可见的
  FBasicInfoTab.TabVisible := True;
  pcEditors.ActivePage := FBasicInfoTab;
end;

procedure TfrmMain.FormDestroy(Sender: TObject);
var
  i: Integer;
  PageInfo: PConfigPageInfo;
begin
  // 保存应用程序设置
  SaveApplicationSettings(Self, meoDebug);
  
  // 清理树型视图中的数据
  CleanupTreeData(tvConfig);
  
  // 释放所有打开的页面信息
  for i := 0 to FOpenPages.Count - 1 do
  begin
    PageInfo := PConfigPageInfo(FOpenPages[i]);
    Dispose(PageInfo);
  end;
  
  FOpenPages.Free;
  FConfigManager.Free;
end;

procedure TfrmMain.InitializeTree;
var
  ConfigFiles: TStringList;
  i: Integer;
  FilePath: string;
  BaseConfigIni: TStringList;
  BaseConfigPath: string;
begin
  tvConfig.Items.Clear;
  
  // 初始化树型视图的分类结构
  InitializeTreeCategories(tvConfig);
  
  // 创建一个测试用的基础配置文件（如果不存在）
  BaseConfigPath := GetCurrentDir + '\config\base_config.ini';
  if not FileExists(BaseConfigPath) then
  begin
    BaseConfigIni := TStringList.Create;
    try
      BaseConfigIni.Add('; 基础配置测试文件');
      BaseConfigIni.Add('[General]');
      BaseConfigIni.Add('AppName=ConfigEditor');
      BaseConfigIni.Add('Version=1.0');
      BaseConfigIni.Add('Language=zh-CN');
      BaseConfigIni.Add('[Interface]');
      BaseConfigIni.Add('Theme=Windows');
      BaseConfigIni.Add('FontSize=10');
      BaseConfigIni.SaveToFile(BaseConfigPath);
      
      FormHelper.AddDebugText(meoDebug, '创建测试用基础配置文件: ' + BaseConfigPath);
    finally
      BaseConfigIni.Free;
    end;
  end;
  
  // 加载当前config目录下的所有配置文件
  ConfigFiles := TStringList.Create;
  try
    // 获取所有INI文件
    FindAllFiles(ConfigFiles, GetCurrentDir + '\config', '*.ini', False);
    for i := 0 to ConfigFiles.Count - 1 do
    begin
      FilePath := ConfigFiles[i];
      FormHelper.AddDebugText(meoDebug, '加载INI配置文件: ' + FilePath);
      
      // 从配置文件中读取属性实体
      LoadPropertiesFromConfigFile(tvConfig, FilePath);
    end;
    
    // 获取所有JSON文件
    ConfigFiles.Clear;
    FindAllFiles(ConfigFiles, GetCurrentDir + '\config', '*.json', False);
    for i := 0 to ConfigFiles.Count - 1 do
    begin
      FilePath := ConfigFiles[i];
      FormHelper.AddDebugText(meoDebug, '加载JSON配置文件: ' + FilePath);
      
      // 从配置文件中读取属性实体
      LoadPropertiesFromConfigFile(tvConfig, FilePath);
    end;
  finally
    ConfigFiles.Free;
  end;
  
  tvConfig.FullExpand;
  
  // 更新调试信息
  FormHelper.AddDebugText(meoDebug, '树型菜单加载完成，包含 ' + IntToStr(tvConfig.Items.Count) + ' 个节点');
end;

procedure TfrmMain.tvConfigDblClick(Sender: TObject);
var
  Node: TTreeNode;
  NodeData: PNodeData;
begin
  try
    Node := tvConfig.Selected;
    if (Node <> nil) and (Node.Data <> nil) then
    begin
      NodeData := PNodeData(Node.Data);
      
      // 处理不同类型的节点
      case NodeData.NodeType of
        ntCategory:
          begin
            // 展开或收缩分类节点
            if Node.Expanded then
              Node.Collapse(False)
            else
              Node.Expand(False);
          end;
          
        ntSection:
          begin
            try
              // 显示详细调试信息
              FormHelper.AddDebugText(meoDebug, '双击节点，尝试加载节内容...');
              FormHelper.AddDebugText(meoDebug, Format('节信息: 类型=%d, 节名=%s, 路径=%s', 
                                    [Ord(NodeData.NodeType), NodeData.SectionName, NodeData.ConfigPath]));
                                    
              // 加载节内容到编辑器
              LoadSectionToEditor(NodeData.ConfigPath, NodeData.SectionName);
              FormHelper.AddDebugText(meoDebug, '双击加载节内容: ' + NodeData.SectionName);
            except
              on E: Exception do
              begin
                FormHelper.AddDebugText(meoDebug, '双击加载节内容时出错: ' + E.Message);
                ShowMessage('加载节内容失败: ' + E.Message);
              end;
            end;
          end;
          
        ntPropertyEntity:
          begin
            // 检查是否应该使用基础信息编辑器
            if SameText(NodeData.CategoryName, '基础配置') or 
               // 简单配置通常节点数量少于10个
               (ShouldUseBasicInfoEditor(NodeData.ConfigPath)) then
            begin
              // 使用基础信息编辑器打开
              LoadBasicInfoToEditor(NodeData.ConfigPath);
            end
            else
            begin
              // 使用普通配置编辑器打开
              OpenConfigEditor(NodeData.ConfigType, NodeData.ConfigPath);
            end;
          end;
      end;
    end;
  except
    on E: Exception do
    begin
      FormHelper.AddDebugText(meoDebug, '双击处理时出现未处理的异常: ' + E.Message);
      ShowMessage('出现错误: ' + E.Message);
    end;
  end;
end;

function TfrmMain.ShouldUseBasicInfoEditor(const ConfigPath: string): Boolean;
var
  FileExt: string;
  IniFile: TMemIniFile;
  JsonFile: TJSONObject;
  Sections: TStringList;
  FileContent: string;
  ItemCount: Integer;
  i: Integer;
begin
  Result := False;
  FileExt := LowerCase(ExtractFileExt(ConfigPath));
  
  // 对于小型配置文件，使用基础信息编辑器
  try
    if FileExt = '.ini' then
    begin
      IniFile := TMemIniFile.Create(ConfigPath, TEncoding.UTF8);
      try
        Sections := TStringList.Create;
        try
          IniFile.ReadSections(Sections);
          
          // 计算总键值对数量
          ItemCount := 0;
          for i := 0 to Sections.Count - 1 do
          begin
            var KeyList := TStringList.Create;
            try
              IniFile.ReadSection(Sections[i], KeyList);
              Inc(ItemCount, KeyList.Count);
            finally
              KeyList.Free;
            end;
          end;
          
          // 如果总键值对数量小于10，认为是简单配置
          Result := (ItemCount < 10);
        finally
          Sections.Free;
        end;
      finally
        IniFile.Free;
      end;
    end
    else if FileExt = '.json' then
    begin
      if FileExists(ConfigPath) then
      begin
        FileContent := TFile.ReadAllText(ConfigPath, TEncoding.UTF8);
        try
          JsonFile := TJSONObject(TJSONObject.ParseJSONValue(FileContent));
          
          if JsonFile <> nil then
          begin
            try
              // 如果JSON对象的键少于10个，认为是简单配置
              Result := (JsonFile.Count < 10);
              
              // 进一步检查是否存在复杂嵌套结构
              if Result then
              begin
                for i := 0 to JsonFile.Count - 1 do
                begin
                  if (JsonFile.Pairs[i].JsonValue is TJSONObject) or
                     (JsonFile.Pairs[i].JsonValue is TJSONArray) then
                  begin
                    // 存在复杂嵌套结构，不适合使用基础信息编辑器
                    Result := False;
                    Break;
                  end;
                end;
              end;
            finally
              JsonFile.Free;
            end;
          end;
        except
          // 如果解析JSON出错，默认使用普通编辑器
          Result := False;
        end;
      end;
    end;
  except
    // 如果解析出错，默认使用普通编辑器
    Result := False;
  end;
end;

procedure TfrmMain.tvConfigChange(Sender: TObject; Node: TTreeNode);
var
  NodeData: PNodeData;
begin
  try
    // 更新右键菜单状态
    UpdateTreeContextMenu(tvConfig, pmTree);
    
    // 更新状态栏信息
    UpdateStatusBar;

    // 检查选中的节点
    if (Node <> nil) and (Node.Data <> nil) then
    begin
      // 确保使用正确的PNodeData类型
      NodeData := TreeHelper.GetSelectedNodeData(tvConfig);
      
      if NodeData <> nil then
      begin
        // 添加调试信息
        FormHelper.AddDebugText(meoDebug, '选中的节点类型: ' + IntToStr(Ord(NodeData.NodeType)) + 
                              ', 分类: ' + NodeData.CategoryName);
        if NodeData.SectionName <> '' then
          FormHelper.AddDebugText(meoDebug, ', 节: ' + NodeData.SectionName);
        FormHelper.AddDebugText(meoDebug, ', 路径: ' + NodeData.ConfigPath);
        
        case NodeData.NodeType of
          // 属性实体节点（具体的配置文件）
          ntPropertyEntity:
            begin
              // 检查是否是简单配置或基础配置
              if SameText(NodeData.CategoryName, '基础配置') or 
                 ShouldUseBasicInfoEditor(NodeData.ConfigPath) then
              begin
                FormHelper.AddDebugText(meoDebug, '符合条件，开始加载配置到值列表编辑器...');
                
                // 使用值列表编辑器加载配置
                LoadBasicInfoToEditor(NodeData.ConfigPath);
                FormHelper.AddDebugText(meoDebug, '加载节点配置到值列表编辑器完成: ' + NodeData.PropertyName);
              end
              else
              begin
                FormHelper.AddDebugText(meoDebug, '不符合条件，跳过加载');
              end;
            end;
            
          // 节点（INI文件中的一个Section或JSON中的根节点）
          ntSection:
            begin
              try
                FormHelper.AddDebugText(meoDebug, '开始加载节的内容到值列表编辑器...');
                
                // 加载该节的内容到值列表编辑器
                LoadSectionToEditor(NodeData.ConfigPath, NodeData.SectionName);
                FormHelper.AddDebugText(meoDebug, '加载节内容到值列表编辑器完成: ' + NodeData.SectionName);
              except
                on E: Exception do
                begin
                  FormHelper.AddDebugText(meoDebug, '加载节内容时出错: ' + E.Message);
                  ShowMessage('加载节内容失败: ' + E.Message);
                end;
              end;
            end;
            
          else
            FormHelper.AddDebugText(meoDebug, '不是可编辑节点类型，跳过加载');
        end;
      end
      else
      begin
        FormHelper.AddDebugText(meoDebug, '无法获取节点数据');
      end;
    end
    else
    begin
      FormHelper.AddDebugText(meoDebug, '选中的节点无效或无数据');
    end;
  except
    on E: Exception do
    begin
      FormHelper.AddDebugText(meoDebug, '处理节点选择时出现未处理的异常: ' + E.Message);
      ShowMessage('出现错误: ' + E.Message);
    end;
  end;
end;

procedure TfrmMain.OpenConfigEditor(const ConfigType, ConfigPath: string);
var
  Index: Integer;
  TabSheet: TTabSheet;
  Editor: TMemo;
  Config: TBaseConfig;
  PageInfo: PConfigPageInfo;
  FileContent: TStringList;
begin
  // 检查是否已经打开
  Index := FindOpenPage(ConfigPath);
  if Index >= 0 then
  begin
    pcEditors.ActivePageIndex := Index;
    Exit;
  end;
  
  // 创建新标签页
  TabSheet := TTabSheet.Create(pcEditors);
  TabSheet.PageControl := pcEditors;
  TabSheet.Caption := ExtractFileName(ConfigPath);
  
  // 创建编辑器控件
  Editor := TMemo.Create(TabSheet);
  Editor.Parent := TabSheet;
  Editor.Align := alClient;
  Editor.ScrollBars := ssBoth;
  Editor.WordWrap := False;
  Editor.Font.Name := 'Consolas'; // 使用等宽字体
  Editor.Font.Size := 10;
  
  // 加载配置内容
  try
    // 创建用于加载文件的字符串列表，使用UTF-8编码
    FileContent := TStringList.Create;
    try
      // 尝试使用不同编码加载文件
      try
        FileContent.LoadFromFile(ConfigPath, TEncoding.UTF8);
      except
        try
          FileContent.LoadFromFile(ConfigPath, TEncoding.Default);
        except
          try
            FileContent.LoadFromFile(ConfigPath); // 尝试使用默认检测
          except
            on E: Exception do
              FileContent.Text := '无法加载文件: ' + E.Message;
          end;
        end;
      end;
      
      // 将内容设置到编辑器
      Editor.Text := FileContent.Text;
      
      // 记录调试信息
      FormHelper.AddDebugText(meoDebug, '成功加载文件: ' + ConfigPath + 
                        ', 大小: ' + IntToStr(Length(Editor.Text)) + 
                        ' 字符, ' + IntToStr(Editor.Lines.Count) + ' 行');
    finally
      FileContent.Free;
    end;
  except
    on E: Exception do
    begin
      Editor.Lines.Text := '加载配置时出错：' + E.Message;
      FormHelper.AddDebugText(meoDebug, '错误: ' + E.Message);
    end;
  end;
  
  // 保存页面信息
  New(PageInfo);
  PageInfo^.Title := ExtractFileName(ConfigPath);
  PageInfo^.ConfigType := ConfigType;
  PageInfo^.ConfigPath := ConfigPath;
  PageInfo^.TabSheet := TabSheet;
  PageInfo^.Modified := False;
  
  FOpenPages.Add(PageInfo);
  
  // 切换到新标签页
  pcEditors.ActivePage := TabSheet;
  UpdateStatusBar;
end;

function TfrmMain.FindOpenPage(const ConfigPath: string): Integer;
var
  i: Integer;
  PageInfo: PConfigPageInfo;
begin
  Result := -1;
  
  for i := 0 to FOpenPages.Count - 1 do
  begin
    PageInfo := PConfigPageInfo(FOpenPages[i]);
    if SameText(PageInfo^.ConfigPath, ConfigPath) then
    begin
      Result := i;
      Break;
    end;
  end;
end;

procedure TfrmMain.CloseConfigPage(Index: Integer);
var
  PageInfo: PConfigPageInfo;
begin
  if (Index < 0) or (Index >= FOpenPages.Count) then
    Exit;
    
  PageInfo := PConfigPageInfo(FOpenPages[Index]);
  
  // 如果有修改，询问是否保存
  if PageInfo^.Modified then
  begin
    case MessageDlg('配置已修改，是否保存？', mtConfirmation, [mbYes, mbNo, mbCancel], 0) of
      mrYes: SaveCurrentConfig;
      mrCancel: Exit;
    end;
  end;
  
  // 删除标签页
  PageInfo^.TabSheet.Free;
  
  // 删除页面信息
  Dispose(PageInfo);
  FOpenPages.Delete(Index);
  
  UpdateStatusBar;
end;

procedure TfrmMain.SaveCurrentConfig;
var
  PageInfo: TConfigPageInfo;
  Editor: TMemo;
  Config: TBaseConfig;
begin
  PageInfo := GetCurrentPageInfo;
  
  if PageInfo.TabSheet = nil then
    Exit;
    
  // 获取当前编辑器内容
  if PageInfo.TabSheet.ControlCount = 0 then
    Exit;
    
  Editor := PageInfo.TabSheet.Controls[0] as TMemo;
  
  // 保存配置文件
  try
    if SameText(PageInfo.ConfigType, 'INI') then
      Config := FConfigManager.GetINI(PageInfo.ConfigPath)
    else if SameText(PageInfo.ConfigType, 'JSON') then
      Config := FConfigManager.GetJSON(PageInfo.ConfigPath)
    else
      Config := nil;
      
    if Config <> nil then
    begin
      // 直接保存编辑器内容到文件
      Editor.Lines.SaveToFile(PageInfo.ConfigPath);
      SetModified(pcEditors.ActivePageIndex, False);
    end
    else
    begin
      ShowMessage('无法保存配置：' + PageInfo.ConfigPath);
    end;
  except
    on E: Exception do
    begin
      ShowMessage('保存配置时出错：' + E.Message);
    end;
  end;
end;

procedure TfrmMain.ValidateCurrentConfig;
var
  PageInfo: TConfigPageInfo;
  Editor: TMemo;
  Config: TBaseConfig;
  ValidationResult: string;
  TempFile: string;
begin
  PageInfo := GetCurrentPageInfo;
  
  if PageInfo.TabSheet = nil then
    Exit;
    
  // 获取当前编辑器内容
  if PageInfo.TabSheet.ControlCount = 0 then
    Exit;
    
  Editor := PageInfo.TabSheet.Controls[0] as TMemo;
  
  // 验证配置文件
  try
    if SameText(PageInfo.ConfigType, 'INI') then
      Config := FConfigManager.GetINI(PageInfo.ConfigPath)
    else if SameText(PageInfo.ConfigType, 'JSON') then
      Config := FConfigManager.GetJSON(PageInfo.ConfigPath)
    else
      Config := nil;
      
    if Config <> nil then
    begin
      ValidationResult := '';
      
      // 创建临时文件进行验证
      TempFile := ChangeFileExt(PageInfo.ConfigPath, '.tmp');
      
      try
        // 保存当前编辑器内容到临时文件
        Editor.Lines.SaveToFile(TempFile);
        
        // 根据配置类型进行简单验证
        if Config is TINIConfig then
        begin
          // 对于INI文件，尝试加载看是否有异常
          try
            var IniFile := TMemIniFile.Create(TempFile);
            try
              // 如果能成功读取，说明格式正确
            finally
              IniFile.Free;
            end;
          except
            on E: Exception do
              ValidationResult := E.Message;
          end;
        end
        else if Config is TJSONConfig then
        begin
          // 对于JSON文件，尝试解析看是否有异常
          try
            var StringList := TStringList.Create;
            try
              StringList.LoadFromFile(TempFile);
              var Content := StringList.Text.Trim;
              if Content = '' then
                ValidationResult := '配置文件内容为空'
              else if not (Content.StartsWith('{') and Content.EndsWith('}')) then
                ValidationResult := '无效的JSON格式，应该以{开始，以}结束';
            finally
              StringList.Free;
            end;
          except
            on E: Exception do
              ValidationResult := E.Message;
          end;
        end;
      finally
        // 删除临时文件
        if FileExists(TempFile) then
          DeleteFile(TempFile);
      end;
      
      if ValidationResult = '' then
        ShowMessage('配置有效')
      else
        ShowMessage('配置无效：' + ValidationResult);
    end
    else
    begin
      ShowMessage('无法验证配置：' + PageInfo.ConfigPath);
    end;
  except
    on E: Exception do
    begin
      ShowMessage('验证配置时出错：' + E.Message);
    end;
  end;
end;

procedure TfrmMain.UpdateStatusBar;
var
  Node: TTreeNode;
  PageInfo: TConfigPageInfo;
  Data: PConfigPageInfo;
  StatusText: string;
begin
  // 更新状态栏信息
  if pcEditors.PageCount > 0 then
  begin
    PageInfo := GetCurrentPageInfo;
    StatusText := '当前文件: ' + PageInfo.ConfigPath;
    
    if PageInfo.Modified then
      StatusText := StatusText + ' [已修改]';
      
    sbMain.Panels[0].Text := StatusText;
  end
  else
  begin
    Node := tvConfig.Selected;
    if (Node <> nil) and (Node.Level > 0) and (Node.Data <> nil) then
    begin
      Data := PConfigPageInfo(Node.Data);
      sbMain.Panels[0].Text := '选中: ' + Data^.ConfigPath;
    end
    else
    begin
      sbMain.Panels[0].Text := '就绪';
    end;
  end;
end;

procedure TfrmMain.SetModified(Index: Integer; Modified: Boolean);
var
  PageInfo: PConfigPageInfo;
begin
  if (Index < 0) or (Index >= FOpenPages.Count) then
    Exit;
    
  PageInfo := PConfigPageInfo(FOpenPages[Index]);
  PageInfo^.Modified := Modified;
  
  // 更新标签页显示
  if Modified then
  begin
    if Pos('*', PageInfo^.TabSheet.Caption) = 0 then
      PageInfo^.TabSheet.Caption := '*' + PageInfo^.TabSheet.Caption;
  end
  else
  begin
    if Pos('*', PageInfo^.TabSheet.Caption) = 1 then
      PageInfo^.TabSheet.Caption := Copy(PageInfo^.TabSheet.Caption, 2, Length(PageInfo^.TabSheet.Caption));
  end;
  
  UpdateStatusBar;
end;

function TfrmMain.GetCurrentPageInfo: TConfigPageInfo;
var
  PageInfo: PConfigPageInfo;
begin
  FillChar(Result, SizeOf(Result), 0);
  
  if (pcEditors.ActivePageIndex >= 0) and (pcEditors.ActivePageIndex < FOpenPages.Count) then
  begin
    PageInfo := PConfigPageInfo(FOpenPages[pcEditors.ActivePageIndex]);
    Result := PageInfo^;
  end;
end;

