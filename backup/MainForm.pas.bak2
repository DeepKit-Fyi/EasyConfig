    mnuCut: TMenuItem;
    mnuCopy: TMenuItem;
    mnuPaste: TMenuItem;
    mnuTools: TMenuItem;
    mnuValidate: TMenuItem;
    mnuHelp: TMenuItem;
    mnuAbout: TMenuItem;
    ilIcons: TImageList;
    pmTree: TPopupMenu;
    pmTreeOpen: TMenuItem;
    pmTreeNew: TMenuItem;
    pmTreeDelete: TMenuItem;
    pmTreeRename: TMenuItem;
    pmEditor: TPopupMenu;
    pmEditorSave: TMenuItem;
    pmEditorClose: TMenuItem;
    pmEditorValidate: TMenuItem;
    dlgOpen: TOpenDialog;
    dlgSave: TSaveDialog;
