unit MainForm;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ComCtrls, Vcl.ExtCtrls,
  Vcl.Menus, Vcl.StdCtrls, Vcl.Buttons, System.ImageList, Vcl.ImgList, System.UITypes,
  System.IniFiles, ConfigManager, BaseConfig, INIConfig, JSONConfig, ConfigTypes,
  Vcl.FileCtrl, System.Skia, Vcl.Skia, System.IOUtils, FormHelper, TreeHelper,
  Vcl.Grids, Vcl.ValEdit, System.JSON, Vcl.Themes, System.Generics.Collections;

type
  PConfigPageInfo = ^TConfigPageInfo;
  TConfigPageInfo = record
    Title: string;
    ConfigType: string;
    ConfigPath: string;
    TabSheet: TTabSheet;
    Modified: Boolean;
  end;

