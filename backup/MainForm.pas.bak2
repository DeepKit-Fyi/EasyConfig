    btnSvgRefresh: TSkSvg;
    btnSvgExit: TSkSvg;
    btnSvgToggle: TSkSvg;
    meoDebug: TMemo;
    meoOutput: TMemo;
    ValueListEditor1: TValueListEditor;
    cbbTheme: TComboBox;
    lblTheme: TLabel;
